# =============================================================
# NUST NEXUS — Environment Variables
# Copy this file as .env and fill in your actual values
# =============================================================

# Vite client-side variables (VITE_ prefix exposes them to the browser)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_STORJ_ENDPOINT=https://gateway.storjshare.io
VITE_STORJ_BUCKET=your_bucket_name_here
VITE_ADMIN_EMAIL=your_admin_email_here

# Storj S3 secrets (used by Supabase Edge Functions)
# Set these via: supabase secrets set STORJ_ACCESS_KEY=xxx STORJ_SECRET_KEY=xxx
STORJ_ACCESS_KEY=your_storj_access_key_here
STORJ_SECRET_KEY=your_storj_secret_key_here
