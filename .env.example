# Supabase (public in browser — anon key only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Storj — public bucket name + endpoint only in the client (files go through Edge Functions)
VITE_STORJ_ENDPOINT=https://gateway.storjshare.io
VITE_STORJ_BUCKET=nust-nexus-uploads

# Do NOT put Storj access/secret keys in Vite. Set them as Supabase Edge Function secrets:
# STORJ_ACCESS_KEY, STORJ_SECRET_KEY, STORJ_ENDPOINT, STORJ_BUCKET

# App
VITE_ADMIN_EMAIL=

# Optional: node test-login.mjs (local only, never commit real passwords)
# TEST_EMAIL=
# TEST_PASSWORD=
